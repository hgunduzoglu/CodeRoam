APP_ENV=development
LOG_LEVEL=debug

CONTROL_PLANE_HTTP_ADDR=:8080
WORKER_CONCURRENCY=4
WORKER_PROCESSING_ENABLED=true
RELAY_HTTP_ADDR=:8090
RELAY_REGION=local
RELAY_PUBLIC_URL=ws://localhost:8090/v1/connect

POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/coderoam?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

SESSION_TICKET_SIGNING_KEY_PATH=./secrets/session-ticket-private.pem
SESSION_TICKET_VERIFY_KEY_PATH=./secrets/session-ticket-public.pem
AGENT_RELEASE_VERIFY_KEY_PATH=./secrets/agent-release-public.pem

PAIRING_TTL=10m
PAIRING_MAX_ATTEMPTS=5
SESSION_TICKET_TTL=60s
SESSION_RESUME_TTL=5m
MAX_FRAME_BYTES=1048576

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

PUBLIC_CONTROL_PLANE_URL=http://localhost:8080
PUBLIC_RELAY_URL=ws://localhost:8090
